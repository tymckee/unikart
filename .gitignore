!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local tooling
.claude/

# Prisma — generated client + local SQLite database (migrations ARE committed)
/src/generated/prisma
prisma/dev.db
prisma/dev.db-journal
prisma/*.db

# Generated AI product cutouts (local imgly provider)
/public/cutouts
