// UniKart — Prisma schema
// Postgres (Neon) for local dev + production. DATABASE_URL = pooled (-pooler)
// connection for runtime queries; DIRECT_URL = direct connection for migrations.
// Enum-like fields are kept as String (carried over from the original SQLite
// design); the TS union types in src/lib/types.ts remain the source of truth and
// are cast in the data-access layer. They could become native PG enums later.

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" for local dev; "rhel-openssl-3.0.x" for Netlify's Linux runtime
  // (Node 20 / OpenSSL 3). Without it, deployed functions fail at runtime with
  // "could not locate the Query Engine for runtime rhel-openssl-3.0.x" once we
  // move off mock data to Postgres. Harmless while still on SQLite.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (-pooler) — runtime queries
  directUrl = env("DIRECT_URL") // direct (no -pooler) — migrations
}

model User {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  emailVerified         Boolean   @default(false) // Better Auth: email ownership confirmed
  image                 String?
  plan                  String    @default("free") // free | pro — app's gating source of truth, mirrored from Stripe
  // Stripe customer id, set by the Better Auth Stripe plugin (createCustomerOnSignUp).
  stripeCustomerId      String?
  // --- Ops Console fields ----------------------------------------------------
  // Access role for the internal Ops Console. Defaults to CUSTOMER (no ops
  // access). One of: OWNER | ADMIN | SUPPORT | FINANCE | READONLY | CUSTOMER.
  // The TS union in src/lib/ops/permissions.ts is the source of truth.
  role                  String    @default("CUSTOMER")
  // Account lifecycle for support/admin: active | disabled. Disabled blocks the
  // customer app at the (app) layout gate.
  status                String    @default("active")
  disabledAt            DateTime?
  // Internal flags an admin can set (never billed, excluded from metrics).
  isTestAccount         Boolean   @default(false)
  isInternal            Boolean   @default(false)
  // Best-effort last-seen timestamp, bumped by trackEvent / app activity.
  lastActiveAt          DateTime?
  // Onboarding completion (resettable by support).
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  products      Product[]
  collections   Collection[]
  alerts        AlertRule[]
  notifications Notification[]
  carts         UniversalCart[]

  // Better Auth relations
  sessions      Session[]
  accounts      Account[]
  passkeys      Passkey[]
  subscriptions Subscription[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([lastActiveAt])
}

model Collection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String   @default("cpu")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  products ProductCollection[]

  @@index([userId])
}

model Product {
  id                 String    @id @default(cuid())
  userId             String
  title              String
  description        String?
  originalUrl        String
  canonicalUrl       String?
  imageUrl           String?
  cutoutUrl          String? // background-removed product shot (AI), preferred on cards
  storeName          String
  storeDomain        String
  brand              String?
  sku                String?
  category           String?
  currency           String    @default("USD")
  currentPrice       Float?
  previousPrice      Float?
  lowestPrice        Float?
  highestPrice       Float?
  availability       String    @default("unknown") // in_stock | low_stock | out_of_stock | preorder | unknown
  metadataConfidence String    @default("low") // high | medium | low
  rawMetadata        String? // JSON blob of what the parser read
  gist               String? // AI "the gist": JSON { summary[], specs[] }
  notes              String?
  isArchived         Boolean   @default(false)
  isPurchased        Boolean   @default(false)
  purchasedAt        DateTime?
  releasedAt         DateTime? // consciously let go of — releasing the urge to buy (no guilt)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastCheckedAt      DateTime?

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  collections    ProductCollection[]
  priceSnapshots PriceSnapshot[]
  stockSnapshots StockSnapshot[]
  alerts         AlertRule[]
  cartItems      UniversalCartItem[]

  @@index([userId])
  @@index([storeDomain])
}

model ProductCollection {
  productId    String
  collectionId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId])
}

model PriceSnapshot {
  id        String   @id @default(cuid())
  productId String
  price     Float
  currency  String   @default("USD")
  source    String   @default("mock") // mock | parser | manual | scheduled
  checkedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model StockSnapshot {
  id           String   @id @default(cuid())
  productId    String
  availability String
  source       String   @default("mock")
  checkedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model AlertRule {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  type        String // price_drop | price_rise | target_price | back_in_stock | out_of_stock
  targetPrice Float?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  productId String?
  cartId    String?
  type      String // price_dropped | target_reached | back_in_stock | out_of_stock | price_increased | cart_reminder | checkout_incomplete
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UniversalCart {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Universal Cart")
  status    String   @default("active") // active | checking_out | completed | archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items UniversalCartItem[]
  steps CheckoutStep[]

  @@index([userId])
}

model UniversalCartItem {
  id             String    @id @default(cuid())
  cartId         String
  productId      String
  quantity       Int       @default(1)
  merchantStatus String    @default("unknown")
  checkoutStatus String    @default("ready") // pending | ready | opened | completed | skipped
  addedAt        DateTime  @default(now())
  completedAt    DateTime?

  cart    UniversalCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
}

model CheckoutStep {
  id                String    @id @default(cuid())
  cartId            String
  storeDomain       String
  storeName         String
  status            String    @default("pending")
  estimatedSubtotal Float     @default(0)
  currency          String    @default("USD")
  checkoutUrl       String?
  itemIds           String    @default("[]") // JSON array of cart item ids
  openedAt          DateTime?
  completedAt       DateTime?

  cart UniversalCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

model IntegrationAdapter {
  id          String   @id @default(cuid())
  name        String
  type        String // merchant | payment | bnpl | agentic | affiliate
  enabled     Boolean  @default(false)
  status      String   @default("planned") // live | planned | beta
  description String
  configJson  String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Better Auth — auth core tables.
// Field names/types match what the Prisma adapter expects (generated via the
// Better Auth CLI). Better Auth supplies its own string ids on insert; the
// @default(cuid()) is a harmless fallback that keeps these rows creatable from
// Prisma directly and consistent with the rest of the schema. No @@map is used
// so table names match the model names, like the existing models.
// ============================================================

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// Subscription — managed by the Better Auth Stripe plugin (@better-auth/stripe).
// Field names/types mirror the plugin's expected schema exactly so its Prisma
// adapter can read/write these rows. `referenceId` is the owning User.id (the
// plugin's default). No @@map, cuid() default — same convention as the rest.
model Subscription {
  id                   String    @id @default(cuid())
  plan                 String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String    @default("incomplete")
  periodStart          DateTime?
  periodEnd            DateTime?
  cancelAtPeriodEnd    Boolean?  @default(false)
  cancelAt             DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  seats                Int?
  trialStart           DateTime?
  trialEnd             DateTime?
  billingInterval      String?
  stripeScheduleId     String?

  user User @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@index([referenceId])
  @@index([stripeCustomerId])
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime? @default(now())
  aaguid       String?

  @@index([userId])
  @@index([credentialID])
}

// ============================================================
// UniKart Ops Console — internal admin / analytics / ops models.
//
// Design notes:
//  - Enum-like fields are kept as String to match the rest of the schema; the
//    TS unions in src/lib/ops/types.ts are the source of truth.
//  - Audit / analytics / usage rows intentionally have NO foreign key to User.
//    They store plain string ids (adminUserId, userId, …) so they survive a
//    user deletion (audit immutability + retained analytics). PII tied to a
//    deleted user is scrubbed explicitly by the DataRequest deletion flow, not
//    by a cascade. See docs/OPS_PRIVACY.md.
//  - Every table is indexed for the admin queries that drive each Ops page.
// ============================================================

/// Immutable record of every sensitive admin mutation. Append-only; never
/// edited or deleted through the UI (see docs/OPS_SECURITY.md).
model AdminAuditLog {
  id           String   @id @default(cuid())
  adminUserId  String
  adminEmail   String
  role         String
  action       String // e.g. "user.role.change", "feature_flag.toggle"
  targetType   String // "user" | "product" | "feature_flag" | "system" | …
  targetId     String?
  targetUserId String?
  reason       String?
  beforeJson   String? // JSON snapshot before the change (sanitized)
  afterJson    String? // JSON snapshot after the change (sanitized)
  metadataJson String? // extra context (sanitized — never secrets/PII bodies)
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([adminUserId])
  @@index([targetType, targetId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

/// First-party, privacy-conscious product analytics. Minimal metadata; hashed
/// IP only when needed. Replaces invasive third-party tracking.
model AnalyticsEvent {
  id           String   @id @default(cuid())
  userId       String?
  sessionId    String?
  eventName    String
  entityType   String?
  entityId     String?
  metadataJson String? // small, sanitized
  source       String   @default("web") // web | extension | system | api
  ipHash       String?
  createdAt    DateTime @default(now())

  @@index([eventName])
  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
}

/// First-party API usage / request telemetry for the costs + usage dashboards.
model APIUsageEvent {
  id               String   @id @default(cuid())
  userId           String?
  route            String
  method           String   @default("GET")
  statusCode       Int      @default(200)
  durationMs       Int?
  requestId        String?
  ipHash           String?
  userAgent        String?
  source           String   @default("internal") // internal | extension | provider | cron
  provider         String? // anthropic | scraperapi | resend | stripe | neon | netlify
  operation        String? // e.g. "gist", "scrape", "send_email"
  quantity         Float?
  unit             String? // tokens | requests | emails | gb …
  estimatedCostUsd Float?
  metadataJson     String? // sanitized — never request bodies with PII
  createdAt        DateTime @default(now())

  @@index([route])
  @@index([provider])
  @@index([userId])
  @@index([statusCode])
  @@index([createdAt])
}

/// Configurable cost ledger. Entries are estimates unless unitCostUsd is a
/// confirmed provider rate (see SystemSetting cost config + docs/OPS_COSTS).
model CostLedgerEntry {
  id               String   @id @default(cuid())
  provider         String // anthropic | scraperapi | resend | stripe | neon | netlify | other
  category         String // hosting | database | storage | email | parser | price_check | stock_check | ai | image | stripe_fees | affiliate | other
  service          String?
  operation        String?
  quantity         Float    @default(1)
  unit             String   @default("request")
  unitCostUsd      Float    @default(0)
  estimatedCostUsd Float    @default(0)
  isEstimate       Boolean  @default(true)
  userId           String?
  productId        String?
  requestId        String?
  metadataJson     String?
  occurredAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([provider])
  @@index([category])
  @@index([occurredAt])
  @@index([userId])
}

/// Observability for background jobs (price/stock checks, enrichment, etc.).
model JobRun {
  id             String    @id @default(cuid())
  jobType        String // price_check | stock_check | parser | notification | cleanup | billing_sync | email
  status         String    @default("queued") // queued | running | succeeded | failed | canceled
  startedAt      DateTime?
  finishedAt     DateTime?
  durationMs     Int?
  itemsProcessed Int       @default(0)
  itemsSucceeded Int       @default(0)
  itemsFailed    Int       @default(0)
  errorCode      String?
  errorMessage   String?
  metadataJson   String?
  createdBy      String? // admin user id for manual runs; null for scheduled
  createdAt      DateTime  @default(now())

  @@index([jobType])
  @@index([status])
  @@index([createdAt])
}

/// One row per URL parse attempt — powers the Parser dashboard (success rates
/// by domain, failure reasons, extraction-source distribution).
model ParseAttempt {
  id               String   @id @default(cuid())
  productId        String?
  userId           String?
  url              String
  domain           String
  status           String // success | partial | failed
  confidence       String? // high | medium | low
  extractionMethod String? // jsonld | opengraph | twitter | ecommerce_meta | html_fallback | manual_fallback
  durationMs       Int?
  errorCode        String?
  errorMessage     String? // sanitized
  metadataJson     String? // sanitized sample of what was read
  createdAt        DateTime @default(now())

  @@index([domain])
  @@index([status])
  @@index([extractionMethod])
  @@index([createdAt])
}

/// Lightweight support ticketing. A ticket may exist for a non-user (email only).
model SupportTicket {
  id           String    @id @default(cuid())
  userId       String?
  email        String
  subject      String
  status       String    @default("open") // open | pending | resolved | closed
  priority     String    @default("normal") // low | normal | high | urgent
  category     String    @default("other") // account | product_saving | parser_failure | price_tracking | stock_tracking | billing | privacy | bug | feedback | other
  assignedToId String?
  productId    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  closedAt     DateTime?

  notes SupportNote[]

  @@index([status])
  @@index([priority])
  @@index([userId])
  @@index([assignedToId])
  @@index([createdAt])
}

/// Notes on a ticket (or directly on a user). Internal by default.
model SupportNote {
  id          String   @id @default(cuid())
  ticketId    String?
  userId      String?
  adminUserId String
  body        String
  visibility  String   @default("internal") // internal | customer
  createdAt   DateTime @default(now())

  ticket SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
  @@index([createdAt])
}

/// Feature flags with rollout controls. Toggled only by authorized roles; every
/// change is audited.
model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique
  name           String
  description    String   @default("")
  enabled        Boolean  @default(false)
  rolloutPercent Int      @default(0)
  allowlistJson  String   @default("[]") // JSON array of emails / user ids
  denylistJson   String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([key])
}

/// Non-secret system configuration (cost rates, tracking cadences, support
/// settings). Secrets live in env vars, never here. JSON value blob.
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  valueJson   String   @default("null")
  category    String   @default("general") // general | costs | parser | tracking | notifications | support | retention
  description String   @default("")
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

/// Data export / deletion requests (privacy). Self-service or admin-queued.
model DataRequest {
  id            String    @id @default(cuid())
  userId        String
  type          String // export | delete
  status        String    @default("pending") // pending | processing | completed | failed | canceled
  requestedById String? // admin user id if queued by an admin; null if self
  reason        String?
  resultUrl     String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}
