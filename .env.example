# Copy this file to `.env` for local development.

# --- Database (Neon Postgres) ------------------------------------------------
# Both local dev and production use Neon. Two connection strings (see
# docs/deploy-postgres.md):
#   DATABASE_URL = POOLED string (host has "-pooler") — runtime queries.
#   DIRECT_URL   = DIRECT string (no "-pooler")       — Prisma migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# If DATABASE_URL is unset, the app gracefully falls back to in-memory mock
# data (read-only), so the site still renders without a database.

# --- AI (Claude) ------------------------------------------------------------
# Powers "the gist" (simplify product descriptions + extract specs). Without a
# key the feature falls back to a deterministic heuristic.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_GIST_MODEL="claude-haiku-4-5"  # cheap; override per task if desired

# --- AI product cutouts (optional) ------------------------------------------
# Background-removal provider for floating product shots (see docs/product-images.md).
# CUTOUT_PROVIDER="removebg"   # default: none (no-op)
# REMOVEBG_API_KEY="..."

# --- Product parsing / scraping (ScraperAPI) --------------------------------
# Fetches real product price/photo/stock from bot-hostile retailers. Without a
# key, parsing falls back to a polite direct fetch (works for cooperative sites
# that expose Open Graph/JSON-LD; bot-walled retailers get the branded tile).
# SCRAPERAPI_KEY="..."
#
# Coverage on the default (no-premium) plan — see docs/product-images.md §coverage:
#   - Amazon + Walmart    → structured endpoints (bulletproof: photo + price + stock)
#   - eBay, Target, Nike, Apple, IKEA, … → direct OG / datacenter render
#   - Home Depot, Best Buy, Lowe's, Costco, Macy's, Wayfair, … (Akamai/PerimeterX
#     walls) → BLOCKED on datacenter proxies; fall back to the branded tile.
#
# To unlock the hard-walled retailers, upgrade to a ScraperAPI plan with premium/
# residential proxies and set this. "ultra" handles the toughest walls (Akamai);
# scrapeRender escalates to it ONLY after a plain render fails, so cheap requests
# stay cheap. Leave unset on the free/hobby plan (those tiers reject the param).
# SCRAPERAPI_PREMIUM="ultra"   # one of: ultra | premium | (unset = datacenter only)

# --- Scheduled jobs ---------------------------------------------------------
# Secret for the price/stock check endpoint (POST /api/jobs/price-check).
# Set this, then point a cron at the endpoint with an Authorization header:
#   curl -X POST https://uni-kart.com/api/jobs/price-check -H "Authorization: Bearer <CRON_SECRET>"
# CRON_SECRET="change-me-to-a-long-random-string"

# --- Auth (Better Auth) -----------------------------------------------------
# Session encryption/signing secret — min 32 chars, high entropy.
# Generate with: openssl rand -base64 32
# REQUIRED in every environment (must also be set on Netlify).
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Canonical base URL for Better Auth (used for callbacks, magic links, passkey
# origin). Optional: falls back to Netlify's $URL, then https://uni-kart.com.
# Locally set to http://localhost:3000.
# BETTER_AUTH_URL="http://localhost:3000"

# --- Transactional email (Resend) -------------------------------------------
# Sends verification + magic-link emails from "UniKart <no-reply@uni-kart.com>".
# Without it, links are logged to the server console instead (dev fallback).
# RESEND_API_KEY="re_..."

# --- UniKart Ops (internal admin console) -----------------------------------
# The Ops Console is served at /ops. In production it is restricted to OPS_HOST
# and returns 404 on the customer domain. See docs/OPS_DEPLOYMENT.md.
#
# Host that serves Ops in production (set the DNS + Netlify domain to match).
OPS_HOST="ops.uni-kart.com"
# Allow /ops on the public/customer host too. Keep false in production; handy
# on a preview deploy. Dev (localhost) always allows /ops regardless.
ALLOW_OPS_ON_PUBLIC_HOST="false"
# Master switch — set to false to hard-disable Ops everywhere (returns 404).
ENABLE_OPS_CONSOLE="true"
# Seed admins: comma-separated emails granted the OWNER role on first sign-in.
# Do NOT hard-code personal emails in source — set them here / on Netlify.
ADMIN_EMAILS=""
# Idle timeout (minutes) surfaced for Ops sessions.
OPS_SESSION_TIMEOUT_MINUTES="60"
# When true, cost figures are labelled as estimates in the UI.
COST_ESTIMATE_MODE="true"
